# Stage 1: Build
FROM golang:1.22-alpine AS builder

WORKDIR /app

COPY go.mod ./
RUN go mod download 2>/dev/null || true

COPY cmd/ ./cmd/
COPY configs/ ./configs/

RUN CGO_ENABLED=0 GOOS=linux go build -o /aiops-gateway ./cmd/server

# Stage 2: Runtime
FROM alpine:3.19

RUN apk add --no-cache wget ca-certificates

WORKDIR /app

COPY --from=builder /aiops-gateway .
COPY configs/ ./configs/

EXPOSE 8090

ENTRYPOINT ["./aiops-gateway"]
