# ERP-AIOps Environment Configuration

# Gateway
PORT=8090
MODULE_NAME=ERP-AIOps
CORS_ORIGINS=http://localhost:5179,http://localhost:3000

# Rust API
RUST_API_URL=http://rust-api:8080
RUST_API_PORT=8080
RUST_LOG=info,opstrac=debug

# Python AI Brain
AI_BRAIN_URL=http://ai-brain:8001
AI_BRAIN_PORT=8001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# YugabyteDB
YUGABYTE_HOST=yugabytedb
YUGABYTE_PORT=5433
YUGABYTE_DB=erp_aiops
YUGABYTE_USER=erp
YUGABYTE_PASSWORD=erp
DATABASE_URL=postgresql://erp:erp@yugabytedb:5433/erp_aiops

# DragonflyDB (Redis-compatible)
DRAGONFLY_HOST=dragonfly
DRAGONFLY_PORT=6379
REDIS_URL=redis://dragonfly:6379

# Hasura GraphQL Engine
HASURA_GRAPHQL_ENDPOINT=http://hasura:19109
HASURA_GRAPHQL_ADMIN_SECRET=hasura-admin-secret
HASURA_GRAPHQL_DATABASE_URL=postgresql://erp:erp@yugabytedb:5433/erp_aiops

# Tenant
DEFAULT_TENANT_ID=default

# Frontend
VITE_HASURA_URL=http://localhost:8090/v1/graphql
VITE_HASURA_WS_URL=ws://localhost:8090/v1/graphql
VITE_GATEWAY_URL=http://localhost:8090
VITE_IAM_URL=http://localhost:8081
